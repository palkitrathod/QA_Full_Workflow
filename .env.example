# JIRA Configuration
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=PROJ

# LLM API (OpenAI or Deepseek)
LLM_API_KEY=your_openai_or_deepseek_key
LLM_BASE_URL=  # Optional: e.g., https://api.deepseek.com/v1
LLM_MODEL=gpt-4o  # e.g., gpt-4o, deepseek-chat

# Slack Configuration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_ALERT_CHANNEL=#qa-alerts
SLACK_REPORT_CHANNEL=#qa-reports

# GitHub Configuration
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_REPO=your-repo-name
GITHUB_OWNER=your-github-username

# Application Under Test
TARGET_APP_URL=https://your-app-staging-url.com
